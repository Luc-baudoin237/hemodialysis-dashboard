library(jsonlite)
library(janitor)
library(stringi)
# -----------------------------
# 1. Chemins des fichiers
# -----------------------------
events_file   <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/events.json"
tei_file      <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/trackedEntities (2).csv"
metadata_file <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/metadata.json"
# dossier de sortie
out_dir <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/dhis2_clean_output"
dir.create(out_dir, showWarnings = FALSE)
# -----------------------------
# 2. Fonction de nettoyage des noms de colonnes
# -----------------------------
clean_var_names <- function(x) {
x %>%
stri_trans_general("Latin-ASCII") %>%   # enlève accents
str_replace_all("[\\r\\n]+", " ") %>%
str_replace_all("[:;/,()\\[\\]\\-]+", "_") %>%
str_replace_all("\\s+", "_") %>%
str_replace_all("[^A-Za-z0-9_]", "") %>%
str_replace_all("_+", "_") %>%
str_replace_all("^_|_$", "") %>%
tolower()
}
# -----------------------------
# 3. Lire les fichiers
# -----------------------------
events_raw <- romJSON(events_file)
# -----------------------------
# 3. Lire les fichiers
# -----------------------------
events_raw <- fromJSON(events_file)
tei_raw    <- read.csv(tei_file, stringsAsFactors = FALSE, check.names = FALSE)
meta_raw   <- fromJSON(metadata_file)
data_elements_dict <- meta_raw$dataElements %>%
as_tibble() %>%
transmute(
dataElement = id,
de_name     = ifelse(!is.na(name) & name != "", name, NA_character_),
de_short    = ifelse(!is.na(shortName) & shortName != "", shortName, NA_character_),
de_code     = ifelse(!is.na(code) & code != "", code, NA_character_)
) %>%
mutate(
variable_label = coalesce(de_short, de_name, de_code, dataElement),
variable_name  = clean_var_names(variable_label)
) %>%
distinct(dataElement, .keep_all = TRUE)
# sauvegarder le dictionnaire
write.csv(data_elements_dict,
file.path(out_dir, "dictionary_data_elements.csv"),
row.names = FALSE)
events_long <- events_raw %>%
mutate(across(everything(), as.character)) %>%
left_join(data_elements_dict, by = "dataElement") %>%
mutate(
variable_label = ifelse(is.na(variable_label) | variable_label == "", dataElement, variable_label),
variable_name  = ifelse(is.na(variable_name)  | variable_name  == "", clean_var_names(dataElement), variable_name)
)
View(events_raw)
events_raw[["events"]]
# -----------------------------
# 0. Packages
# -----------------------------
library(tidyverse)
library(jsonlite)
library(janitor)
library(stringi)
# -----------------------------
# 1. Chemins des fichiers
# -----------------------------
events_file   <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/events.json"
tei_file      <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/trackedEntities (2).csv"
metadata_file <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/metadata.json"
out_dir <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/dhis2_clean_output_json"
dir.create(out_dir, showWarnings = FALSE)
# -----------------------------
# 2. Fonction de nettoyage
# -----------------------------
clean_var_names <- function(x) {
x %>%
stri_trans_general("Latin-ASCII") %>%
str_replace_all("[\\r\\n]+", " ") %>%
str_replace_all("[:;/,()\\[\\]\\-]+", "_") %>%
str_replace_all("\\s+", "_") %>%
str_replace_all("[^A-Za-z0-9_]", "") %>%
str_replace_all("_+", "_") %>%
str_replace_all("^_|_$", "") %>%
tolower()
}
# -----------------------------
# 3. Lire metadata.json
# -----------------------------
meta_raw <- fromJSON(metadata_file)
data_elements_dict <- meta_raw$dataElements %>%
as_tibble() %>%
transmute(
dataElement = id,
de_name     = ifelse(!is.na(name) & name != "", name, NA_character_),
de_short    = ifelse(!is.na(shortName) & shortName != "", shortName, NA_character_),
de_code     = ifelse(!is.na(code) & code != "", code, NA_character_)
) %>%
mutate(
variable_label = coalesce(de_short, de_name, de_code, dataElement),
variable_name  = clean_var_names(variable_label)
) %>%
distinct(dataElement, .keep_all = TRUE)
write.csv(
data_elements_dict,
file.path(out_dir, "dictionary_data_elements.csv"),
row.names = FALSE
)
# -----------------------------
# 4. Lire events.json
# -----------------------------
events_json <- fromJSON(events_file, flatten = TRUE)
# vérifier l'objet principal
if ("events" %in% names(events_json)) {
events_tbl <- as_tibble(events_json$events)
} else {
events_tbl <- as_tibble(events_json)
}
# sécuriser colonnes minimales
needed_event_cols <- c(
"event", "status", "program", "programStage", "enrollment", "trackedEntity",
"orgUnit", "occurredAt", "scheduledAt", "storedBy", "followUp", "deleted",
"createdAt", "updatedAt", "completedAt"
)
for (col in needed_event_cols) {
if (!col %in% names(events_tbl)) events_tbl[[col]] <- NA
}
# -----------------------------
# 5. Déplier les dataValues
# -----------------------------
events_long <- events_tbl %>%
select(all_of(needed_event_cols), dataValues) %>%
unnest(dataValues) %>%
mutate(across(everything(), as.character))
# -----------------------------
# 5. Déplier les dataValues (version corrigée)
# -----------------------------
events_long <- events_tbl %>%
select(all_of(needed_event_cols), dataValues) %>%
unnest(dataValues, names_sep = "_") %>%
mutate(across(everything(), as.character))
# si certaines colonnes dataValues n'existent pas
if (!"dataElement" %in% names(events_long)) events_long$dataElement <- NA
if (!"value" %in% names(events_long)) events_long$value <- NA
# joindre le dictionnaire
events_long_labeled <- events_long %>%
left_join(data_elements_dict, by = "dataElement") %>%
mutate(
variable_label = ifelse(is.na(variable_label) | variable_label == "", dataElement, variable_label),
variable_name  = ifelse(is.na(variable_name)  | variable_name  == "", clean_var_names(dataElement), variable_name)
)
write.csv(
events_long_labeled,
file.path(out_dir, "events_long_labeled.csv"),
row.names = FALSE
)
# -----------------------------
# 6. Passer events en format large
# -----------------------------
event_id_cols <- c(
"event", "status", "program", "programStage", "enrollment", "trackedEntity",
"orgUnit", "occurredAt", "scheduledAt", "storedBy", "followUp", "deleted",
"createdAt", "updatedAt", "completedAt"
)
events_wide <- events_long_labeled %>%
select(all_of(event_id_cols), variable_name, value) %>%
filter(!is.na(variable_name), variable_name != "") %>%
group_by(across(all_of(c(event_id_cols, "variable_name")))) %>%
summarise(
value = paste(unique(na.omit(value[value != ""])), collapse = "; "),
.groups = "drop"
) %>%
pivot_wider(
names_from = variable_name,
values_from = value
) %>%
janitor::clean_names()
write.csv(
events_wide,
file.path(out_dir, "events_wide_clean.csv"),
row.names = FALSE
)
# -----------------------------
# 7. Lire trackedEntities CSV
# -----------------------------
tei_raw <- read.csv(tei_file, stringsAsFactors = FALSE, check.names = FALSE)
tei_long <- tei_raw %>%
mutate(across(everything(), as.character)) %>%
mutate(
attr_label = case_when(
"displayName" %in% names(.) & !is.na(displayName) & displayName != "" ~ displayName,
"attribute"   %in% names(.) & !is.na(attribute) & attribute != "" ~ attribute,
TRUE ~ "unknown_attribute"
),
attr_name = clean_var_names(attr_label)
)
tei_id_cols <- c(
"trackedEntity", "trackedEntityType", "createdAt", "updatedAt", "orgUnit",
"inactive", "deleted", "potentialDuplicate", "storedBy"
)
tei_id_cols <- intersect(tei_id_cols, names(tei_long))
tei_wide <- tei_long %>%
select(all_of(tei_id_cols), attr_name, value) %>%
filter(!is.na(attr_name), attr_name != "") %>%
group_by(across(all_of(c(tei_id_cols, "attr_name")))) %>%
summarise(
value = paste(unique(na.omit(value[value != ""])), collapse = "; "),
.groups = "drop"
) %>%
pivot_wider(
names_from = attr_name,
values_from = value
) %>%
janitor::clean_names()
write.csv(
tei_wide,
file.path(out_dir, "tracked_entities_wide_clean.csv"),
row.names = FALSE
)
# -----------------------------
# 8. Fusion finale par trackedEntity
# -----------------------------
# important: après clean_names(), trackedEntity devient tracked_entity
if (!"tracked_entity" %in% names(events_wide)) {
stop("La colonne trackedEntity n'a pas été retrouvée dans events_wide.")
}
if (!"tracked_entity" %in% names(tei_wide)) {
stop("La colonne trackedEntity n'a pas été retrouvée dans tei_wide.")
}
final_merged <- events_wide %>%
left_join(
tei_wide,
by = "tracked_entity",
suffix = c("_event", "_tei")
)
write.csv(
final_merged,
file.path(out_dir, "final_merged_tracker_database.csv"),
row.names = FALSE
)
# -----------------------------
# 9. Petit résumé
# -----------------------------
cat("\n====================================\n")
cat("FICHIERS CREES DANS : ", out_dir, "\n")
cat("====================================\n")
cat("- dictionary_data_elements.csv\n")
cat("- events_long_labeled.csv\n")
cat("- events_wide_clean.csv\n")
cat("- tracked_entities_wide_clean.csv\n")
cat("- final_merged_tracker_database.csv\n")
cat("====================================\n")
cat("\nDimensions events_wide : ", dim(events_wide)[1], " lignes x ", dim(events_wide)[2], " colonnes\n", sep = "")
cat("Dimensions tei_wide    : ", dim(tei_wide)[1], " lignes x ", dim(tei_wide)[2], " colonnes\n", sep = "")
cat("Dimensions final_merged: ", dim(final_merged)[1], " lignes x ", dim(final_merged)[2], " colonnes\n", sep = "")
View(final_merged)
# -----------------------------
# 0. Packages
# -----------------------------
library(tidyverse)
library(jsonlite)
library(janitor)
library(stringi)
# -----------------------------
# 1. Chemins des fichiers
# -----------------------------
events_file   <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/events.json"
tei_file      <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/trackedEntities (2).csv"
metadata_file <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/metadata.json"
out_dir <- "C:/Users/ekinz/OneDrive/Desktop/hemodialysis databases/dhis2_clean_output_json"
dir.create(out_dir, showWarnings = FALSE)
# -----------------------------
# 2. Fonction de nettoyage des noms
# -----------------------------
clean_var_names <- function(x) {
x %>%
stri_trans_general("Latin-ASCII") %>%
str_replace_all("[\\r\\n]+", " ") %>%
str_replace_all("[:;/,()\\[\\]\\-]+", "_") %>%
str_replace_all("\\s+", "_") %>%
str_replace_all("[^A-Za-z0-9_]", "") %>%
str_replace_all("_+", "_") %>%
str_replace_all("^_|_$", "") %>%
tolower()
}
# -----------------------------
# 3. Lire metadata.json et créer le dictionnaire
# -----------------------------
meta_raw <- fromJSON(metadata_file, simplifyVector = TRUE)
data_elements_dict <- meta_raw$dataElements %>%
as_tibble() %>%
transmute(
dataElement = id,
de_name     = ifelse(!is.na(name) & name != "", name, NA_character_),
de_short    = ifelse(!is.na(shortName) & shortName != "", shortName, NA_character_),
de_code     = ifelse(!is.na(code) & code != "", code, NA_character_)
) %>%
mutate(
variable_label = coalesce(de_short, de_name, de_code, dataElement),
variable_name  = clean_var_names(variable_label)
) %>%
distinct(dataElement, .keep_all = TRUE)
write.csv(
data_elements_dict,
file.path(out_dir, "dictionary_data_elements.csv"),
row.names = FALSE
)
# -----------------------------
# 4. Lire events.json
# -----------------------------
events_json <- fromJSON(events_file, flatten = TRUE)
if ("events" %in% names(events_json)) {
events_tbl <- as_tibble(events_json$events)
} else {
events_tbl <- as_tibble(events_json)
}
# colonnes minimales à conserver
needed_event_cols <- c(
"event", "status", "program", "programStage", "enrollment", "trackedEntity",
"orgUnit", "occurredAt", "scheduledAt", "storedBy", "followUp", "deleted",
"createdAt", "updatedAt", "completedAt"
)
for (col in needed_event_cols) {
if (!col %in% names(events_tbl)) {
events_tbl[[col]] <- NA
}
}
# -----------------------------
# 5. Déplier les dataValues correctement
# -----------------------------
events_long <- events_tbl %>%
select(all_of(needed_event_cols), dataValues) %>%
unnest(dataValues, names_sep = "_") %>%
mutate(across(everything(), as.character)) %>%
rename(
dataElement = dataValues_dataElement,
value = dataValues_value
)
cat("Dimensions events_long :", dim(events_long)[1], "lignes x", dim(events_long)[2], "colonnes\n")
# -----------------------------
# 6. Ajouter les noms des variables
# -----------------------------
events_long_labeled <- events_long %>%
left_join(data_elements_dict, by = "dataElement") %>%
mutate(
variable_label = ifelse(is.na(variable_label) | variable_label == "", dataElement, variable_label),
variable_name  = ifelse(is.na(variable_name)  | variable_name  == "", clean_var_names(dataElement), variable_name)
)
write.csv(
events_long_labeled,
file.path(out_dir, "events_long_labeled.csv"),
row.names = FALSE
)
cat("Dimensions events_long_labeled :", dim(events_long_labeled)[1], "lignes x", dim(events_long_labeled)[2], "colonnes\n")
# -----------------------------
# 7. Passer les events en format large
#    1 ligne = 1 event
# -----------------------------
event_id_cols <- c(
"event", "status", "program", "programStage", "enrollment", "trackedEntity",
"orgUnit", "occurredAt", "scheduledAt", "storedBy", "followUp", "deleted",
"createdAt", "updatedAt", "completedAt"
)
events_wide <- events_long_labeled %>%
select(all_of(event_id_cols), variable_name, value) %>%
filter(!is.na(variable_name), variable_name != "") %>%
group_by(across(all_of(c(event_id_cols, "variable_name")))) %>%
summarise(
value = paste(unique(na.omit(value[value != ""])), collapse = "; "),
.groups = "drop"
) %>%
pivot_wider(
names_from = variable_name,
values_from = value
) %>%
janitor::clean_names()
write.csv(
events_wide,
file.path(out_dir, "events_wide_clean.csv"),
row.names = FALSE
)
cat("Dimensions events_wide :", dim(events_wide)[1], "lignes x", dim(events_wide)[2], "colonnes\n")
# -----------------------------
# 8. Lire trackedEntities CSV
# -----------------------------
tei_raw <- read.csv(tei_file, stringsAsFactors = FALSE, check.names = FALSE)
# Vérifier les noms de colonnes
cat("\nColonnes de tei_raw :\n")
print(names(tei_raw))
# -----------------------------
# 9. Organiser tracked entities
#    1 ligne = 1 attribut d'un individu
# -----------------------------
tei_long <- tei_raw %>%
mutate(across(everything(), as.character)) %>%
mutate(
attr_label = case_when(
"displayName" %in% names(.) & !is.na(displayName) & displayName != "" ~ displayName,
"attribute" %in% names(.) & !is.na(attribute) & attribute != "" ~ attribute,
TRUE ~ "unknown_attribute"
),
attr_name = clean_var_names(attr_label)
)
tei_id_cols <- c(
"trackedEntity", "trackedEntityType", "createdAt", "updatedAt", "orgUnit",
"inactive", "deleted", "potentialDuplicate", "storedBy"
)
tei_id_cols <- intersect(tei_id_cols, names(tei_long))
tei_wide <- tei_long %>%
select(all_of(tei_id_cols), attr_name, value) %>%
filter(!is.na(attr_name), attr_name != "") %>%
group_by(across(all_of(c(tei_id_cols, "attr_name")))) %>%
summarise(
value = paste(unique(na.omit(value[value != ""])), collapse = "; "),
.groups = "drop"
) %>%
pivot_wider(
names_from = attr_name,
values_from = value
) %>%
janitor::clean_names()
write.csv(
tei_wide,
file.path(out_dir, "tracked_entities_wide_clean.csv"),
row.names = FALSE
)
cat("Dimensions tei_wide :", dim(tei_wide)[1], "lignes x", dim(tei_wide)[2], "colonnes\n")
# -----------------------------
# 10. Dictionnaire des attributs tracked entity
# -----------------------------
tei_dictionary <- tei_long %>%
select(any_of(c("attribute", "displayName", "attr_name", "valueType"))) %>%
distinct()
write.csv(
tei_dictionary,
file.path(out_dir, "dictionary_tracked_entity_attributes.csv"),
row.names = FALSE
)
# -----------------------------
# 11. Fusion finale par tracked_entity
# -----------------------------
if (!"tracked_entity" %in% names(events_wide)) {
stop("La colonne tracked_entity n'a pas été retrouvée dans events_wide.")
}
if (!"tracked_entity" %in% names(tei_wide)) {
stop("La colonne tracked_entity n'a pas été retrouvée dans tei_wide.")
}
final_merged <- events_wide %>%
left_join(
tei_wide,
by = "tracked_entity",
suffix = c("_event", "_tei")
)
write.csv(
final_merged,
file.path(out_dir, "final_merged_tracker_database.csv"),
row.names = FALSE
)
cat("Dimensions final_merged :", dim(final_merged)[1], "lignes x", dim(final_merged)[2], "colonnes\n")
# -----------------------------
# 12. Aperçus utiles
# -----------------------------
cat("\nAperçu events_long :\n")
print(head(events_long[, c("event", "trackedEntity", "dataElement", "value")], 5))
cat("\nAperçu events_wide :\n")
print(head(events_wide, 3))
cat("\nAperçu tei_wide :\n")
print(head(tei_wide, 3))
cat("\nAperçu final_merged :\n")
print(head(final_merged, 3))
# -----------------------------
# 13. Résumé final
# -----------------------------
cat("\n====================================\n")
cat("FICHIERS CREES DANS : ", out_dir, "\n")
cat("====================================\n")
cat("- dictionary_data_elements.csv\n")
cat("- dictionary_tracked_entity_attributes.csv\n")
cat("- events_long_labeled.csv\n")
cat("- events_wide_clean.csv\n")
cat("- tracked_entities_wide_clean.csv\n")
cat("- final_merged_tracker_database.csv\n")
cat("====================================\n")
setwd("C:/Users/ekinz/OneDrive/Desktop/dashboard hemo")
setwd("C:/Users/ekinz/OneDrive/Desktop/dashboard hemo/modules")
setwd("C:/Users/ekinz/OneDrive/Desktop/dashboard hemo")
list.files()
shiny::runApp()
